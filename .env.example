# ================================
# Database Configuration
# ================================

# MySQL JDBC URL
# 예시: jdbc:mysql://localhost:3306/umc10th?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_URL=jdbc:mysql://localhost:3306/{데이터베이스명}?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8

# MySQL 유저 이름
DB_USER=root

# MySQL 비밀번호
DB_PW=your_password_here

